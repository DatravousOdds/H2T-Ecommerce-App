<?xml version="1.0" encoding="UTF-8"?>
<!--
  Only lists standalone content pages with a fixed URL. Product listings
  (/products/:id) and seller profiles (/sellerProfile) are excluded --
  they're rendered client-side from Firestore data, so a static sitemap
  can't enumerate them. Generating that list would need a server-side job
  that queries Firestore for active listings; out of scope for this pass.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://hexxo.store/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
